# Database (cPanel MySQL) — replace YOUR_* with real values on the server only
DATABASE_URL="mysql://YOUR_DB_USER:YOUR_DB_PASSWORD@127.0.0.1:3306/YOUR_DB_NAME"

# Auth / site URL (used for SSLCommerz callback URLs)
NEXTAUTH_URL=https://gbbfashion.com
NEXT_PUBLIC_SITE_URL=https://gbbfashion.com
NEXTAUTH_SECRET=generate-a-long-random-string

# SSLCommerz — sandbox: https://developer.sslcommerz.com
SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWORD=qwerty
SSLCOMMERZ_IS_LIVE=false
NEXT_PUBLIC_SSLCOMMERZ_IS_LIVE=false

# SMTP — cPanel mailbox
SMTP_HOST=mail.gbbfashion.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=admin@gbbfashion.com
SMTP_PASS=YOUR_MAIL_PASSWORD
SMTP_FROM="GBB Fashion <admin@gbbfashion.com>"
# If mail hangs or TLS fails on cPanel, try PORT=587 + SECURE=false, and:
# SMTP_TLS_REJECT_UNAUTHORIZED=false
