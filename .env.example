# Database
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/gbbfashion"

# Auth / site URL (used for SSLCommerz callback URLs)
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me

# SSLCommerz — sandbox credentials from https://developer.sslcommerz.com
# Sandbox dashboard: https://sandbox.sslcommerz.com/manage/
# Sandbox always shows SSLCommerz's plain TESTBOX OTP page (Success / Failed buttons).
# The premium customer UI only appears with LIVE store credentials + SSLCOMMERZ_IS_LIVE=true
SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWORD=qwerty
SSLCOMMERZ_IS_LIVE=false
NEXT_PUBLIC_SSLCOMMERZ_IS_LIVE=false

# SMTP — invoice PDF emails (required on production server for optional checkout email)
# Example: cPanel / hosting mail, or Gmail app password, or any SMTP relay
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-mailbox-password
SMTP_FROM="GBB Fashion <noreply@yourdomain.com>"
# Optional for shared hosts with self-signed certs:
# SMTP_TLS_REJECT_UNAUTHORIZED=false
