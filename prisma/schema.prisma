generator client {
  provider      = "prisma-client-js"
  // native = local/CI; rhel = CloudLinux/cPanel Passenger hosts
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  password        String
  role            String   @default("customer")
  /** signup = self-registered customer | admin = created from admin panel */
  source          String   @default("signup")
  phone           String?
  shippingAddress String?  @db.Text
  city            String?
  state           String?
  zipCode         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
}

model Category {
  id              String        @id @default(cuid())
  slug            String        @unique
  label           String
  highlight       Boolean       @default(false)
  showInNav       Boolean       @default(true)
  sortOrder       Int           @default(0)
  /** Special shop modes: new-arrivals | prime-drop | null for normal categories */
  specialType     String?
  heroTitle       String?
  heroSubtitle    String?
  heroDescription String?       @db.Text
  heroImageLeft   String?
  heroImageRight  String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subcategories   SubCategory[]
}

model SubCategory {
  id             String   @id @default(cuid())
  categoryId     String
  slug           String
  label          String
  sortOrder      Int      @default(0)
  heroImageLeft  String?
  heroImageRight String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@index([categoryId])
}

model Product {
  id             String      @id @default(cuid())
  name           String
  /** Public URL segment — usually from featured image filename */
  slug           String?     @unique
  description    String      @db.Text
  price          Float
  originalPrice  Float?
  category       String
  /** Subcategory slug within category — managed from admin */
  subCategory    String?
  image          String
  secondaryImage String?
  /** JSON: [{ name, swatch, image }] — color gallery used on storefront swatches */
  galleryImages  String?     @db.Text
  features       String      @db.Text
  rating         Float       @default(4.5)
  /** Units available — inStock is derived as stock > 0 */
  stock          Int         @default(100)
  inStock        Boolean     @default(true)
  badge          String?
  colors         String?     @db.Text
  collection     String?
  hasFlash       Boolean     @default(false)
  /** Homepage / shop placements — controlled from admin */
  isNewArrival   Boolean     @default(false)
  isPrimeDrop    Boolean     @default(false)
  isFeatured     Boolean     @default(false)
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]

  @@index([category])
  @@index([isNewArrival])
  @@index([isPrimeDrop])
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String      @db.Text
  city            String
  state           String
  zipCode         String
  totalAmount     Float
  /** Order fulfillment: pending | processing | shipped | delivered | cancelled | returning | exchanging | returned | exchanged */
  status          String      @default("pending")
  /** Payment channel: cod | sslcommerz */
  paymentMethod   String      @default("cod")
  /** unpaid | pending | paid | failed | cancelled | refunded | partial_refund */
  paymentStatus   String      @default("unpaid")
  /** SSLCommerz tran_id (usually same as order id) */
  transactionId   String?
  sslValId        String?
  sslBankTranId   String?
  sslCardType     String?
  paidAt          DateTime?
  /** JSON snapshot of gateway validation / IPN payload (sanitized summary) */
  paymentMeta     String?     @db.Text
  items           OrderItem[]
  returns         OrderReturn[]
  user            User?       @relation(fields: [userId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([paymentStatus])
  @@index([paymentMethod])
  @@index([transactionId])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  /** Nullable after product is deleted — productName/price snapshot remains on the order */
  productId   String?
  productName String
  quantity    Int
  price       Float
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

/**
 * Admin-managed return or exchange for a delivered order.
 * type: return | exchange
 * status: pending | completed | cancelled
 */
model OrderReturn {
  id           String            @id @default(cuid())
  orderId      String
  type         String
  status       String            @default("completed")
  reason       String?           @db.Text
  notes        String?           @db.Text
  /** Amount refunded to customer (return) or price difference adjustment */
  refundAmount Float             @default(0)
  /** Whether returned units were added back to inventory */
  restocked    Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  order        Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items        OrderReturnItem[]

  @@index([orderId])
  @@index([type])
  @@index([status])
}

model OrderReturnItem {
  id                   String      @id @default(cuid())
  returnId             String
  orderItemId          String
  quantity             Int
  productId            String?
  /** Snapshot of returned line label */
  productName          String
  unitPrice            Float       @default(0)
  /** Exchange only — unit price of the replacement color/size */
  exchangeUnitPrice    Float?
  /** Exchange only — replacement variant encoded like order lines */
  exchangeProductName  String?
  exchangeColor        String?
  exchangeSize         String?
  returnRecord         OrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([orderItemId])
}

model Reel {
  id             String   @id @default(cuid())
  title          String
  productName    String
  price          Float
  originalPrice  Float?
  videoSrc       String
  videoThumbnail String
  thumbnail      String
  /** Units available for the reel product */
  stock          Int      @default(50)
  /** JSON: [{ name, hex, image }] color / image variants for the reel product */
  colors         String?  @db.Text
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
